# ─── Whisper Model ────────────────────────────────────────
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ─── Redis (sesiones en memoria por defecto) ──────────────
REDIS_URL=redis://127.0.0.1:6379
REDIS_SESSION_ENABLED=false
TRANSCRIPTION_STREAM=transcriptions

# ─── Kafka (para enviar a saau) ───────────────────────────
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_TOPIC=transcriptions.raw

# ─── Sesión WebSocket ─────────────────────────────────────
CHUNK_INTERVAL_MS=500
MAX_CHUNK_SIZE_BYTES=131072
MAX_SESSIONS=100
MAX_BUFFER_MB=50
HEARTBEAT_INTERVAL_SECONDS=15
HEARTBEAT_TIMEOUT_SECONDS=30
SESSION_TIMEOUT_SECONDS=600

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=/var/log/saau/speech-service.log
